{
  "name": "linguoup",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "start": "./start.sh",
    "dev": "pnpm --filter './apps/*' dev",
    "build": "pnpm --filter './apps/*' build",
    "lint": "pnpm --filter './apps/*' --filter './packages/*' lint",
    "typecheck": "pnpm --filter './apps/*' --filter './packages/*' typecheck",
    "test": "pnpm --filter './apps/*' --filter './packages/*' test",
    "db:migrate": "pnpm --filter=@linguoup/database migrate",
    "db:migrate:dev": "pnpm --filter=@linguoup/database migrate:dev",
    "db:seed": "pnpm --filter=@linguoup/database seed",
    "db:studio": "pnpm --filter=@linguoup/database studio"
  },
  "devDependencies": {}
}
