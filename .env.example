# ─────────────────────────────────────────────────────────────────────────────
# LinguoUp — Environment Variables Example
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=linguoup
POSTGRES_PASSWORD=linguoup_dev
POSTGRES_DB=linguoup
POSTGRES_PORT=5432

# Prisma / Application connection string
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL="redis://localhost:${REDIS_PORT}"

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@linguoup.local
PGADMIN_PASSWORD=linguoup_admin
PGADMIN_PORT=5050

# ── API (NestJS) ──────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
# (runs on port 3001 by default — see apps/web/package.json)

# ── Auth (placeholder for CHG-004) ───────────────────────────────────────────
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_AUDIENCE=

# ── Docker / Container Runtime ────────────────────────────────────────────────
# Used by Docker containers in production (not needed for local dev with compose)
# API container
# DATABASE_URL="postgresql://user:password@postgres-host:5432/linguoup?schema=public"
# REDIS_URL="redis://redis-host:6379"

# Web container
# PORT=3001
# HOSTNAME=0.0.0.0

# ── CI/CD Secrets (configure as GitHub Actions Secrets, NOT in .env) ──────────
# The following are GitHub Actions secrets — never put real values here.
# Configure at: Settings → Secrets and variables → Actions

# SONAR_TOKEN=               # SonarCloud authentication token
# EXPO_TOKEN=                # Expo / EAS authentication token
# ECR_REGISTRY=              # AWS ECR registry URL (e.g., 123456789.dkr.ecr.us-east-1.amazonaws.com)
# AWS_ACCESS_KEY_ID=         # AWS credentials for ECR push
# AWS_SECRET_ACCESS_KEY=     # AWS credentials for ECR push
