# ─────────────────────────────────────────────────────────────────────────────
# LinguoUp — Environment Variables Example
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=linguoup
POSTGRES_PASSWORD=linguoup_dev
POSTGRES_DB=linguoup
POSTGRES_PORT=5432

# Prisma / Application connection string
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL="redis://localhost:${REDIS_PORT}"

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@linguoup.local
PGADMIN_PASSWORD=linguoup_admin
PGADMIN_PORT=5050

# ── API (NestJS) ──────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ── Web (Next.js) ─────────────────────────────────────────────────────────────
# (runs on port 3001 by default — see apps/web/package.json)
# URL da API backend — deve apontar para Railway em produção
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Auth (CHG-004) ────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Docker / Container Runtime ────────────────────────────────────────────────
# Used by Docker containers in production (not needed for local dev with compose)
# API container
# DATABASE_URL="postgresql://user:password@postgres-host:5432/linguoup?schema=public"
# REDIS_URL="redis://redis-host:6379"

# Web container
# PORT=3001
# HOSTNAME=0.0.0.0

# ── CI/CD Secrets (configure as GitHub Actions Secrets, NOT in .env) ──────────
# The following are GitHub Actions secrets — never put real values here.
# Configure at: Settings → Secrets and variables → Actions

# SONAR_TOKEN=               # SonarCloud authentication token
# EXPO_TOKEN=                # Expo / EAS authentication token
# ECR_REGISTRY=              # AWS ECR registry URL (e.g., 123456789.dkr.ecr.us-east-1.amazonaws.com)
# AWS_ACCESS_KEY_ID=         # AWS credentials for ECR push
# AWS_SECRET_ACCESS_KEY=     # AWS credentials for ECR push

# ── Notifications (CHG-010) ───────────────────────────────────────────────────
# Firebase Cloud Messaging — service account JSON (base64 or raw JSON string)
# FCM_SERVICE_ACCOUNT_JSON=<paste-your-firebase-service-account-json-here>

# AWS SES — transactional email
# AWS_SES_FROM_EMAIL=no-reply@linguoup.com
# AWS_SES_REGION=us-east-1
# ── Grafana Cloud (CHG-011) ───────────────────────────────────────────────────
# Variables needed to forward metrics/logs to Grafana Cloud.
# Only used when running docker-compose with docker-compose.grafana-cloud.yml.
# Get these values from your Grafana Cloud portal (https://grafana.com)
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-blocks-prod-us-central-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USER=your_prometheus_user_id
GRAFANA_CLOUD_PROMETHEUS_API_KEY=your_grafana_cloud_api_key_or_token

GRAFANA_CLOUD_LOKI_URL=https://logs-prod-us-central-0.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=your_loki_user_id
GRAFANA_CLOUD_LOKI_API_KEY=your_grafana_cloud_api_key_or_token
